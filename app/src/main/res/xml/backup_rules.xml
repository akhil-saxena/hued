<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!-- Exclude the database (it's a cache, rebuilt from gallery) -->
    <exclude domain="database" path="hued-database" />
    <exclude domain="database" path="hued-database-shm" />
    <exclude domain="database" path="hued-database-wal" />
    <!-- Include DataStore preferences (onboarding state, dev settings) -->
    <include domain="file" path="datastore/" />
</full-backup-content>
